# Переопределение URL внешних сервисов. Файл-пример: скопируй в .env
# и поменяй значения при необходимости. Без переменных используются
# боевые значения по умолчанию (см. src/lib/api.ts).

# База контента book-club-data (raw.githubusercontent.com)
VITE_RAW_BASE=https://raw.githubusercontent.com/bookclubit/book-club-data/main

# HTTP API телеграм-бота (Cloudflare Workers)
VITE_BOT_API=https://book-club-bot.vitrumbeta.workers.dev
